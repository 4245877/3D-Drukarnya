---
import '../styles/base.css';
import '../styles/layout.css';
import SiteHeader from './SiteHeader.astro';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  image?: string;
  imageAlt?: string;
  keywords?: string;
  ogType?: 'website' | 'product';
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalPath = '/',
  image,
  imageAlt,
  keywords = '3D-друк Київ, FDM друк Київ, 3D друк на замовлення, друк PLA Київ, друк PETG Київ, корпуси для електроніки, прототипування Київ',
  ogType = 'website',
  noindex = false,
} = Astro.props;

const SITE_NAME = '3D Друкарня';
// The site's branded OG image. Dimensions verified against the actual file
// (PNG IHDR: 1983×793) — never publish unconfirmed sizes.
const DEFAULT_OG_IMAGE = '/OGimage.png';
const DEFAULT_OG_IMAGE_WIDTH = '1983';
const DEFAULT_OG_IMAGE_HEIGHT = '793';
const DEFAULT_OG_IMAGE_ALT = 'FDM 3D-друк у Києві — 3D Друкарня';
const SKUFNYA_URL = 'https://www.skufnya.com/';

/**
 * MIME type of an image URL, only when it can be derived from the URL itself
 * (extension or an explicit `format,<type>` CDN directive). Product photos
 * from the CDN are `…format,webp`, so they must never be declared image/png.
 */
const detectImageMime = (url: string): string | undefined => {
  const value = url.toLowerCase();
  if (/format,webp/.test(value) || /\.webp(?:[?#]|$)/.test(value)) return 'image/webp';
  if (/format,png/.test(value) || /\.png(?:[?#]|$)/.test(value)) return 'image/png';
  if (/format,jpe?g/.test(value) || /\.jpe?g(?:[?#]|$)/.test(value)) return 'image/jpeg';
  if (/\.svg(?:[?#]|$)/.test(value)) return 'image/svg+xml';
  return undefined;
};

const site = Astro.site ?? new URL('https://4245877.github.io');
const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const absoluteBaseUrl = new URL(basePath, site);
const normalizedCanonicalPath =
  canonicalPath === '/' ? '' : canonicalPath.replace(/^\/+/, '');
const canonicalUrl = new URL(normalizedCanonicalPath, absoluteBaseUrl).toString();
const sitemapUrl = new URL('sitemap.xml', absoluteBaseUrl).toString();

const toAbsoluteUrl = (value: string) => {
  if (/^https?:\/\//i.test(value)) return value;
  if (/^\/\//.test(value)) return `https:${value}`;

  return new URL(value.replace(/^\/+/, ''), absoluteBaseUrl).toString();
};

const imagePath = image?.trim() || DEFAULT_OG_IMAGE;
const resolvedImage = toAbsoluteUrl(imagePath);
const defaultOgImageUrl = toAbsoluteUrl(DEFAULT_OG_IMAGE);
const isDefaultOgImage = resolvedImage === defaultOgImageUrl;
const resolvedImageAlt = isDefaultOgImage
  ? imageAlt || DEFAULT_OG_IMAGE_ALT
  : imageAlt || title;
const resolvedImageMime = detectImageMime(resolvedImage);

const currentYear = new Date().getFullYear();
const faviconIcoPath = `${import.meta.env.BASE_URL}favicon.ico`;
const favicon16Path = `${import.meta.env.BASE_URL}favicon-16x16.png`;
const favicon32Path = `${import.meta.env.BASE_URL}favicon-32x32.png`;
const appleTouchIconPath = `${import.meta.env.BASE_URL}apple-touch-icon.png`;
---

<!DOCTYPE html>
<html lang="uk">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="google-site-verification"
      content="Tl9FVjxmrqwkZmthujRbUlfNyj9DIqujas0TUkC0MzM"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {/*
      GitHub Pages does not allow custom HTTP response headers, so security
      policies that have a real, standardized <meta> equivalent are set here.
      <meta name="referrer"> is the spec-defined in-document form of
      Referrer-Policy; X-Frame-Options/Permissions-Policy/HSTS have no working
      <meta> form and are intentionally NOT faked here. See README.
    */}
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" type="application/xml" href={sitemapUrl} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="uk_UA" />

    {/*
      Primary og:image. og:image:type is only declared when the MIME type can
      be derived from the URL itself (product CDN photos are WebP — they must
      not be labelled image/png); width/height only for the branded default,
      whose dimensions are verified against the real file.
    */}
    <meta property="og:image" content={resolvedImage} />
    <meta property="og:image:secure_url" content={resolvedImage} />
    {resolvedImageMime && <meta property="og:image:type" content={resolvedImageMime} />}
    {isDefaultOgImage && <meta property="og:image:width" content={DEFAULT_OG_IMAGE_WIDTH} />}
    {isDefaultOgImage && <meta property="og:image:height" content={DEFAULT_OG_IMAGE_HEIGHT} />}
    <meta property="og:image:alt" content={resolvedImageAlt} />
    {/*
      Branded fallback: when the primary image is a remote product photo, the
      site's own OG image is offered as a second candidate for scrapers that
      cannot use the remote WebP.
    */}
    {!isDefaultOgImage && (
      <>
        <meta property="og:image" content={defaultOgImageUrl} />
        <meta property="og:image:secure_url" content={defaultOgImageUrl} />
        <meta property="og:image:type" content="image/png" />
        <meta property="og:image:width" content={DEFAULT_OG_IMAGE_WIDTH} />
        <meta property="og:image:height" content={DEFAULT_OG_IMAGE_HEIGHT} />
        <meta property="og:image:alt" content={DEFAULT_OG_IMAGE_ALT} />
      </>
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:image" content={resolvedImage} />
    <meta name="twitter:image:alt" content={resolvedImageAlt} />
    <meta name="theme-color" content="#8E3F43" />

    <link rel="icon" href={faviconIcoPath} sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href={favicon32Path} />
    <link rel="icon" type="image/png" sizes="16x16" href={favicon16Path} />
    <link rel="apple-touch-icon" sizes="180x180" href={appleTouchIconPath} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;0,700;0,800;0,900;1,500;1,600&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Mulish:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />
  </head>

  <body>
    <SiteHeader />

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container site-footer__inner">
        <div>
          <strong>{SITE_NAME}</strong>
          <p class="site-footer__text">
            FDM 3D-друк у Києві: PLA, PETG, корпуси для електроніки, прототипи та деталі на замовлення.
          </p>
        </div>

        <div class="site-footer__meta">
          <a
            class="site-footer__link"
            href={SKUFNYA_URL}
            target="_blank"
            rel="noopener noreferrer"
          >
            SKUFNYA
          </a>
          <span>© {currentYear}</span>
        </div>
      </div>
    </footer>

    <script>
      // Local fallback for product images (~170 of them come from a single
      // external CDN). Opt-in via data-img-fallback; no inline onerror, the
      // <img> is never removed, and swapping to the local placeholder can
      // never loop (a failing placeholder just marks the image as final).
      const PLACEHOLDER_SRC = `${import.meta.env.BASE_URL}images/product-placeholder.svg`;

      const applyFallback = (image: HTMLImageElement) => {
        if (image.dataset.fallbackApplied === 'true') return;
        image.dataset.fallbackApplied = 'true';
        if (new URL(image.src, document.baseURI).pathname.endsWith('product-placeholder.svg')) return;
        image.src = PLACEHOLDER_SRC;
        if (image.srcset) image.removeAttribute('srcset');
      };

      // Capture-phase listener: <img> error events do not bubble.
      document.addEventListener(
        'error',
        (event) => {
          const target = event.target;
          if (
            target instanceof HTMLImageElement &&
            target.hasAttribute('data-img-fallback')
          ) {
            applyFallback(target);
          }
        },
        true,
      );

      // Images that already failed before this module ran.
      document
        .querySelectorAll<HTMLImageElement>('img[data-img-fallback]')
        .forEach((image) => {
          if (image.complete && image.naturalWidth === 0) applyFallback(image);
        });
    </script>
  </body>
</html>
