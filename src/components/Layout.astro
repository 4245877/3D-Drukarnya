---
import '../styles/base.css';
import '../styles/layout.css';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  image?: string;
  imageAlt?: string;
  keywords?: string;
}

const {
  title,
  description,
  canonicalPath = '/',
  image,
  imageAlt,
  keywords = '3D друк Київ, 3D друкарня, друк на замовлення, 3D товари, FDM друк',
} = Astro.props;

const DEFAULT_OG_IMAGE = '/OGimage.png';
const DEFAULT_OG_IMAGE_WIDTH = '1983';
const DEFAULT_OG_IMAGE_HEIGHT = '793';

const site = Astro.site ?? new URL('https://4245877.github.io');
const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const absoluteBaseUrl = new URL(basePath, site);
const normalizedCanonicalPath =
  canonicalPath === '/' ? '' : canonicalPath.replace(/^\/+/, '');
const canonicalUrl = new URL(normalizedCanonicalPath, absoluteBaseUrl).toString();

const toAbsoluteUrl = (value: string) => {
  if (/^https?:\/\//i.test(value)) return value;
  if (/^\/\//.test(value)) return `https:${value}`;

  return new URL(value.replace(/^\/+/, ''), absoluteBaseUrl).toString();
};

const imagePath = image?.trim() || DEFAULT_OG_IMAGE;
const resolvedImage = toAbsoluteUrl(imagePath);
const isDefaultOgImage = resolvedImage === toAbsoluteUrl(DEFAULT_OG_IMAGE);
const resolvedImageAlt = imageAlt || title;

const currentYear = new Date().getFullYear();
const logoPath = `${import.meta.env.BASE_URL}logo.svg`;
---

<!DOCTYPE html>
<html lang="uk">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="google-site-verification"
      content="Tl9FVjxmrqwkZmthujRbUlfNyj9DIqujas0TUkC0MzM"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="3D Друкарня" />
    <meta property="og:locale" content="uk_UA" />

    <meta property="og:image" content={resolvedImage} />
    <meta property="og:image:secure_url" content={resolvedImage} />
    {isDefaultOgImage && <meta property="og:image:type" content="image/png" />}
    {isDefaultOgImage && <meta property="og:image:width" content={DEFAULT_OG_IMAGE_WIDTH} />}
    {isDefaultOgImage && <meta property="og:image:height" content={DEFAULT_OG_IMAGE_HEIGHT} />}
    <meta property="og:image:alt" content={resolvedImageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedImage} />
    <meta name="twitter:image:alt" content={resolvedImageAlt} />

    <link rel="icon" type="image/svg+xml" href={logoPath} />
    <link rel="shortcut icon" href={logoPath} />
    <link rel="apple-touch-icon" href={logoPath} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Mulish:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />
  </head>

  <body>
    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container site-footer__inner">
        <div>
          <strong>3D Друкарня</strong>
          <p class="site-footer__text">
            Каталог 3D-друкованих виробів, аксесуарів та корисних рішень на замовлення.
          </p>
        </div>

        <div class="site-footer__meta">
          <span>© {currentYear}</span>
        </div>
      </div>
    </footer>
  </body>
</html>
