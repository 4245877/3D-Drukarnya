---
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const OLX_URL = 'https://www.olx.ua/uk/list/user/15L7LS/';

const links = [
  { label: 'Каталог', href: base },
  { label: 'Послуги', href: `${base}#services-title` },
  { label: 'Матеріали', href: `${base}#materials-title` },
  { label: 'Доставка', href: `${base}#order-title` },
];
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="site-header__logo" href={base} aria-label="3D Друкарня — на головну">
      <span class="site-header__logo-mark" aria-hidden="true">3D</span>
      <span class="site-header__logo-text">Друкарня</span>
    </a>

    <nav class="site-header__nav" aria-label="Головна навігація">
      {links.map((link) => (
        <a class="site-header__link" href={link.href}>{link.label}</a>
      ))}
    </nav>

    <a
      class="btn btn--primary btn--sm site-header__cta"
      href={OLX_URL}
      target="_blank"
      rel="noopener noreferrer"
    >
      Замовити
    </a>

    <button
      class="site-header__burger"
      type="button"
      aria-label="Відкрити меню"
      aria-expanded="false"
      aria-controls="site-header-menu"
    >
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav
    id="site-header-menu"
    class="site-header__drawer"
    aria-label="Мобільна навігація"
  >
    {links.map((link) => (
      <a class="site-header__drawer-link" href={link.href}>{link.label}</a>
    ))}
  </nav>
</header>

<script>
  const burger = document.querySelector<HTMLButtonElement>('.site-header__burger');
  const drawer = document.getElementById('site-header-menu');

  if (burger && drawer) {
    const setOpen = (open: boolean) => {
      burger.setAttribute('aria-expanded', String(open));
      burger.setAttribute('aria-label', open ? 'Закрити меню' : 'Відкрити меню');
      drawer.classList.toggle('is-open', open);
    };

    burger.addEventListener('click', () => {
      setOpen(burger.getAttribute('aria-expanded') !== 'true');
    });

    drawer.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') setOpen(false);
    });
  }
</script>
