---
import '../styles/components/gallery.css';

interface Props {
  title: string;
  images: string[];
}

const { title, images = [] } = Astro.props as Props;

const normalizeImageUrl = (image: string) => {
  if (!image) return '';

  if (/^https?:\/\//i.test(image)) return image;
  if (/^\/\//.test(image)) return `https:${image}`;

  const base = import.meta.env.BASE_URL || '/';
  return `${base.replace(/\/$/, '')}/${image.replace(/^\/+/, '')}`;
};

const preparedImages = images
  .map((image) => normalizeImageUrl(image))
  .filter(Boolean);

const [mainImage] = preparedImages;
const imageCount = preparedImages.length;
---

{
  mainImage && (
    <div class="product-gallery" data-product-gallery data-gallery-title={title}>
      <a
        class="product-gallery__main"
        href={mainImage}
        target="_blank"
        rel="noopener"
        aria-label={`Збільшити фото 1 з ${imageCount} товару ${title}`}
        aria-haspopup="dialog"
        data-gallery-open
      >
        <img
          src={mainImage}
          alt={`${title} — головне фото`}
          width="1200"
          height="1200"
          loading="eager"
          decoding="async"
          data-gallery-main-image
        />
      </a>

      {
        imageCount > 1 && (
          <div class="product-gallery__thumbs" aria-label={`Фото товару ${title}`}>
            {preparedImages.map((image, index) => (
              <a
                class="product-gallery__thumb"
                href={image}
                target="_blank"
                rel="noopener"
                aria-label={`Показати фото ${index + 1} товару ${title}`}
                aria-current={index === 0 ? 'true' : 'false'}
                data-gallery-thumb
                data-image={image}
                data-alt={index === 0 ? `${title} — головне фото` : `${title} — фото ${index + 1}`}
              >
                <img
                  src={image}
                  alt=""
                  loading="lazy"
                  decoding="async"
                  width="320"
                  height="320"
                />
              </a>
            ))}
          </div>
        )
      }

      <dialog
        class="product-gallery__dialog"
        aria-label={`Збільшене фото товару ${title}`}
        data-gallery-dialog
      >
        <button
          type="button"
          class="product-gallery__close"
          aria-label="Закрити збільшене фото"
          data-gallery-close
        >
          <span aria-hidden="true">&times;</span>
        </button>

        {
          imageCount > 1 && (
            <>
              <button
                type="button"
                class="product-gallery__nav product-gallery__nav--previous"
                aria-label="Показати попереднє фото"
                data-gallery-previous
              >
                <svg aria-hidden="true" viewBox="0 0 24 24">
                  <path d="m15 18-6-6 6-6" />
                </svg>
              </button>

              <button
                type="button"
                class="product-gallery__nav product-gallery__nav--next"
                aria-label="Показати наступне фото"
                data-gallery-next
              >
                <svg aria-hidden="true" viewBox="0 0 24 24">
                  <path d="m9 18 6-6-6-6" />
                </svg>
              </button>

              <p class="product-gallery__counter" aria-live="polite" aria-atomic="true">
                <span data-gallery-current>1</span> / {imageCount}
              </p>
            </>
          )
        }

        <img
          src={mainImage}
          alt={`${title} — головне фото`}
          width="1600"
          height="1600"
          decoding="async"
          draggable="false"
          data-gallery-dialog-image
        />
      </dialog>
    </div>
  )
}

<script>
  document.querySelectorAll<HTMLElement>('[data-product-gallery]').forEach((gallery) => {
    if (gallery.dataset.galleryInitialized === 'true') return;

    const mainImage = gallery.querySelector<HTMLImageElement>('[data-gallery-main-image]');
    const openLink = gallery.querySelector<HTMLAnchorElement>('[data-gallery-open]');
    const dialog = gallery.querySelector<HTMLDialogElement>('[data-gallery-dialog]');
    const dialogImage = gallery.querySelector<HTMLImageElement>('[data-gallery-dialog-image]');
    const closeButton = gallery.querySelector<HTMLButtonElement>('[data-gallery-close]');
    const previousButton = gallery.querySelector<HTMLButtonElement>('[data-gallery-previous]');
    const nextButton = gallery.querySelector<HTMLButtonElement>('[data-gallery-next]');
    const currentNumber = gallery.querySelector<HTMLElement>('[data-gallery-current]');
    const thumbnails = Array.from(
      gallery.querySelectorAll<HTMLAnchorElement>('[data-gallery-thumb]'),
    );

    if (!mainImage || !openLink || !dialog || !dialogImage || !closeButton) return;

    const galleryTitle = gallery.dataset.galleryTitle ?? '';
    const items =
      thumbnails.length > 0
        ? thumbnails.map((thumbnail) => ({
            image: thumbnail.dataset.image ?? '',
            alt: thumbnail.dataset.alt ?? '',
          }))
        : [{ image: openLink.href, alt: mainImage.alt }];

    if (items.some(({ image, alt }) => !image || !alt)) return;

    gallery.dataset.galleryInitialized = 'true';

    let currentIndex = Math.max(
      0,
      thumbnails.findIndex((thumbnail) => thumbnail.getAttribute('aria-current') === 'true'),
    );

    const selectImage = (index: number) => {
      currentIndex = (index + items.length) % items.length;

      const { image, alt } = items[currentIndex];
      mainImage.src = image;
      mainImage.alt = alt;
      dialogImage.src = image;
      dialogImage.alt = alt;
      openLink.href = image;
      openLink.setAttribute(
        'aria-label',
        `Збільшити фото ${currentIndex + 1} з ${items.length} товару ${galleryTitle}`,
      );

      if (currentNumber) {
        currentNumber.textContent = String(currentIndex + 1);
      }

      thumbnails.forEach((thumbnail, thumbnailIndex) => {
        thumbnail.setAttribute('aria-current', String(thumbnailIndex === currentIndex));
      });
    };

    thumbnails.forEach((thumbnail, index) => {
      thumbnail.addEventListener('click', (event) => {
        event.preventDefault();
        selectImage(index);
      });
    });

    openLink.addEventListener('click', (event) => {
      if (typeof dialog.showModal !== 'function') return;

      event.preventDefault();
      dialogImage.src = mainImage.currentSrc || mainImage.src;
      dialogImage.alt = mainImage.alt;

      if (!dialog.open) {
        dialog.showModal();
      }
    });

    closeButton.addEventListener('click', () => {
      if (dialog.open) dialog.close();
    });

    previousButton?.addEventListener('click', () => selectImage(currentIndex - 1));
    nextButton?.addEventListener('click', () => selectImage(currentIndex + 1));

    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) dialog.close();
    });

    dialog.addEventListener('keydown', (event) => {
      if (items.length < 2) return;

      if (event.key === 'ArrowLeft') {
        event.preventDefault();
        selectImage(currentIndex - 1);
      }

      if (event.key === 'ArrowRight') {
        event.preventDefault();
        selectImage(currentIndex + 1);
      }

      if (event.key === 'Home') {
        event.preventDefault();
        selectImage(0);
      }

      if (event.key === 'End') {
        event.preventDefault();
        selectImage(items.length - 1);
      }
    });
  });
</script>
