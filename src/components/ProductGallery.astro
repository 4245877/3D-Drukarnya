---
import { withBase } from '../utils/products';

import '../styles/components/gallery.css';
import { withBase } from '../utils/products';

interface Props {
  title: string;
  images: string[];
}

const { title, images } = Astro.props;
const [mainImage, ...otherImages] = images;
---

<div class="product-gallery">
  <a
    class="product-gallery__main"
    href={withBase(mainImage)}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={`Відкрити головне фото товару ${title}`}
  >
    <img
      src={withBase(mainImage)}
      alt={`${title} — головне фото`}
      width="900"
      height="900"
    />
  </a>

  {
    otherImages.length > 0 && (
      <div class="product-gallery__thumbs">
        {otherImages.map((image, index) => (
          <a
            class="product-gallery__thumb"
            href={withBase(image)}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Відкрити фото ${index + 2} товару ${title}`}
          >
            <img
              src={withBase(image)}
              alt={`${title} — фото ${index + 2}`}
              loading="lazy"
              width="320"
              height="320"
            />
          </a>
        ))}
      </div>
    )
  }
</div>