---
import { truncate } from '../utils/text';
import { isSafeSlug, normalizeSlug } from '../data/product.schema.mjs';

const SKUFNYA_URL = 'https://www.skufnya.com/';
const SKUFNYA_PRODUCTS_API = 'https://api.skufnya.com/api/catalog/products/home';
const MAX_PRODUCTS = 4;
const FETCH_TIMEOUT_MS = 3500;

// Only images from these hosts (or their subdomains) are rendered; anything
// else falls back to the branded placeholder. Extend deliberately if SKUFNYA
// moves its media to a CDN.
const TRUSTED_IMAGE_HOSTS = ['skufnya.com'];

interface SkufnyaProductCard {
  title: string;
  url: string;
  imageUrl: string;
  imageAlt: string;
  label: string;
  meta: string;
  description: string;
  price: string;
}

const isRecord = (value: unknown): value is Record<string, unknown> =>
  typeof value === 'object' && value !== null;

const getString = (value: unknown) =>
  typeof value === 'string' ? value.trim() : '';

const formatPrice = (amount: unknown, currencyValue: unknown) => {
  if (typeof amount !== 'number' || !Number.isFinite(amount) || amount <= 0) {
    return '';
  }

  const currency = getString(currencyValue) || 'UAH';
  const currencyLabel = currency === 'UAH' ? '₴' : currency;

  return `від ${new Intl.NumberFormat('uk-UA').format(amount)} ${currencyLabel}`;
};

const isTrustedImageHost = (hostname: string) =>
  TRUSTED_IMAGE_HOSTS.some(
    (trusted) => hostname === trusted || hostname.endsWith(`.${trusted}`),
  );

// Accepts only absolute https:// URLs pointing at a trusted host. Rejects
// javascript:, data: and every other scheme, so the value is safe to put
// into an <img src>.
const sanitizeImageUrl = (value: unknown): string => {
  const raw = getString(value);
  if (!raw) return '';

  let url: URL;
  try {
    url = new URL(raw);
  } catch {
    return '';
  }

  if (url.protocol !== 'https:' || !isTrustedImageHost(url.hostname)) return '';

  return url.toString();
};

const normalizeProduct = (item: unknown): SkufnyaProductCard | null => {
  if (!isRecord(item)) return null;

  const title = getString(item.title);
  // Normalize first (trim, strip surrounding slashes), then validate: a value
  // like "///" normalizes to an empty string and is rejected by the slug
  // pattern instead of slipping through into the URL.
  const slug = normalizeSlug(item.slug);

  if (!title || !isSafeSlug(slug)) return null;

  const coverImage = isRecord(item.coverImage) ? item.coverImage : {};
  const category = isRecord(item.category) ? item.category : {};
  const defaultVariant = isRecord(item.defaultVariant) ? item.defaultVariant : {};
  const categoryName = getString(category.name);
  const series = getString(item.series);
  const sizeLabel = getString(defaultVariant.sizeLabel);

  return {
    title,
    url: new URL(`product/${encodeURIComponent(slug)}/`, SKUFNYA_URL).toString(),
    imageUrl: sanitizeImageUrl(coverImage.url),
    imageAlt: getString(coverImage.alt) || title,
    label: categoryName || 'Колекційна модель',
    meta: [series, sizeLabel].filter(Boolean).join(' · '),
    description: truncate(getString(item.shortDescription), 132),
    price: formatPrice(item.priceFrom, item.currency),
  };
};

const parseProducts = (payload: unknown) => {
  if (!isRecord(payload) || !Array.isArray(payload.items)) return [];

  return payload.items
    .map(normalizeProduct)
    .filter((product): product is SkufnyaProductCard => product !== null)
    .slice(0, MAX_PRODUCTS);
};

const fetchSkufnyaProducts = async () => {
  const controller = new AbortController();
  const timeoutId = setTimeout(() => controller.abort(), FETCH_TIMEOUT_MS);

  try {
    const response = await fetch(SKUFNYA_PRODUCTS_API, {
      headers: { Accept: 'application/json' },
      signal: controller.signal,
    });

    if (!response.ok) {
      throw new Error(`SKUFNYA API responded with ${response.status}`);
    }

    return parseProducts(await response.json());
  } catch (error) {
    console.warn(
      'SKUFNYA promo fallback is used because products could not be loaded.',
      error
    );
    return [];
  } finally {
    clearTimeout(timeoutId);
  }
};

const products = await fetchSkufnyaProducts();
const hasProducts = products.length > 0;
---

<section class="skufnya-promo" aria-labelledby="skufnya-promo-title">
  <div class="container">
    <div class="skufnya-promo__header">
      <div class="skufnya-promo__copy">
        <p class="kicker">Друга вітрина</p>
        <h2 id="skufnya-promo-title">Також наш магазин: SKUFNYA</h2>
        <p>
          Аніме-фігурки, колекційні моделі та товари для фанатів з доставкою по Україні.
        </p>
      </div>

      <a
        class="btn btn--ghost skufnya-promo__main-link"
        href={SKUFNYA_URL}
        target="_blank"
        rel="noopener noreferrer"
      >
        Перейти до SKUFNYA
      </a>
    </div>

    {
      hasProducts ? (
        <div class="skufnya-promo__grid" aria-label="Рекомендовані товари SKUFNYA">
          {products.map((product) => (
            <article class="skufnya-promo-card">
              <a
                class="skufnya-promo-card__image-link"
                href={product.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Відкрити товар SKUFNYA: ${product.title}`}
              >
                <span class="skufnya-promo-card__image-placeholder" aria-hidden="true">
                  SKUFNYA
                </span>
                {product.imageUrl && (
                  <img
                    class="skufnya-promo-card__image"
                    src={product.imageUrl}
                    alt={product.imageAlt}
                    width="420"
                    height="420"
                    loading="lazy"
                    decoding="async"
                  />
                )}
              </a>

              <div class="skufnya-promo-card__body">
                <p class="skufnya-promo-card__label">{product.label}</p>

                <h3 class="skufnya-promo-card__title">
                  <a href={product.url} target="_blank" rel="noopener noreferrer">
                    {product.title}
                  </a>
                </h3>

                {product.meta && <p class="skufnya-promo-card__meta">{product.meta}</p>}
                {product.description && (
                  <p class="skufnya-promo-card__description">{product.description}</p>
                )}
                {product.price && <p class="skufnya-promo-card__price">{product.price}</p>}

                <a
                  class="btn btn--secondary btn--sm skufnya-promo-card__link"
                  href={product.url}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Дивитися товар
                </a>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="skufnya-promo__fallback">
          <ul class="skufnya-promo__benefits" role="list" aria-label="Переваги SKUFNYA">
            <li>Аніме-фігурки та фан-арт моделі</li>
            <li>Добірка для колекцій і подарунків</li>
            <li>Доставка Новою поштою та Укрпоштою</li>
          </ul>

          <a
            class="btn btn--secondary skufnya-promo__fallback-link"
            href={SKUFNYA_URL}
            target="_blank"
            rel="noopener noreferrer"
          >
            Дивитися товари SKUFNYA
          </a>
        </div>
      )
    }
  </div>
</section>

<script>
  // Replaces the former inline `onerror="this.remove()"` handler (removed to
  // keep the markup free of inline event handlers, CSP-ready). If a promo
  // image fails to load, drop it so the branded placeholder underneath shows.
  document
    .querySelectorAll<HTMLImageElement>('.skufnya-promo-card__image')
    .forEach((image) => {
      // Already failed before this script ran (e.g. eager cache miss).
      if (image.complete && image.naturalWidth === 0) {
        image.remove();
        return;
      }

      image.addEventListener('error', () => image.remove(), { once: true });
    });
</script>

<style>
  .skufnya-promo {
    padding: var(--space-10) 0 var(--space-12);
    background:
      linear-gradient(180deg, rgba(245, 237, 224, 0.72), rgba(232, 216, 190, 0.46));
    border-top: var(--border-faint);
    border-bottom: var(--border-faint);
  }

  .skufnya-promo__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-6);
    margin-bottom: var(--space-6);
  }

  .skufnya-promo__copy {
    max-width: 720px;
  }

  /* Eyebrow uses the shared global .kicker component from base.css */

  .skufnya-promo__copy h2 {
    margin: 0 0 var(--space-3);
    color: var(--chocolate);
    font-size: clamp(1.45rem, 2.7vw, 2.25rem);
  }

  .skufnya-promo__copy p {
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .skufnya-promo__main-link,
  .skufnya-promo__fallback-link {
    flex-shrink: 0;
    text-align: center;
    white-space: normal;
  }

  .skufnya-promo__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-4);
  }

  /* Same radius/border/shadow tokens as the product cards, so the two
     card families on the page read as one system. */
  .skufnya-promo-card {
    display: flex;
    min-width: 0;
    height: 100%;
    flex-direction: column;
    overflow: hidden;
    background: rgba(245, 237, 224, 0.82);
    border: var(--border-soft);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    transition:
      border-color var(--dur-normal) var(--ease-out),
      box-shadow var(--dur-normal) var(--ease-out),
      transform var(--dur-normal) var(--ease-out);
  }

  .skufnya-promo-card:hover {
    transform: translateY(-3px);
    border-color: rgba(142, 63, 67, 0.28);
    box-shadow: var(--shadow-md);
  }

  .skufnya-promo-card__image-link {
    display: grid;
    aspect-ratio: 1 / 1;
    place-items: center;
    overflow: hidden;
    background:
      radial-gradient(circle at 50% 20%, rgba(255, 255, 255, 0.2), transparent 44%),
      linear-gradient(135deg, rgba(217, 154, 116, 0.16), rgba(142, 63, 67, 0.1));
  }

  /* Placeholder and image share one cell: the image covers the placeholder
     while it loads, and the branded fallback stays visible if it never does. */
  .skufnya-promo-card__image-link > * {
    grid-area: 1 / 1;
  }

  .skufnya-promo-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-slow) var(--ease-out);
  }

  .skufnya-promo-card:hover .skufnya-promo-card__image {
    transform: scale(1.04);
  }

  .skufnya-promo-card__image-placeholder {
    color: var(--burgundy);
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: var(--fw-black);
    letter-spacing: 0.08em;
  }

  .skufnya-promo-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-4);
  }

  .skufnya-promo-card__label,
  .skufnya-promo-card__meta,
  .skufnya-promo-card__description,
  .skufnya-promo-card__price {
    margin: 0;
  }

  .skufnya-promo-card__label {
    align-self: flex-start;
    max-width: 100%;
    padding: 0.25rem 0.65rem;
    overflow: hidden;
    border: var(--border-soft);
    border-radius: var(--radius-full);
    background: rgba(232, 216, 190, 0.7);
    color: var(--text-muted);
    font-size: var(--fs-xs);
    font-weight: var(--fw-semibold);
    line-height: 1.3;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .skufnya-promo-card__title {
    margin: 0;
    color: var(--chocolate);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    line-height: 1.25;
  }

  .skufnya-promo-card__title a {
    display: -webkit-box;
    overflow: hidden;
    color: inherit;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
  }

  .skufnya-promo-card__title a:hover {
    color: var(--burgundy);
  }

  .skufnya-promo-card__meta {
    overflow: hidden;
    color: var(--text-muted);
    font-size: var(--fs-xs);
    font-weight: var(--fw-semibold);
    line-height: 1.4;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .skufnya-promo-card__description {
    display: -webkit-box;
    overflow: hidden;
    color: var(--text-secondary);
    font-size: var(--fs-sm);
    line-height: 1.55;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    line-clamp: 3;
  }

  .skufnya-promo-card__price {
    margin-top: auto;
    color: var(--burgundy);
    font-family: var(--font-serif);
    font-size: var(--fs-lg);
    font-weight: var(--fw-semibold);
    line-height: 1.2;
  }

  .skufnya-promo-card__link {
    width: 100%;
    min-height: 2.4rem;
    text-align: center;
    white-space: normal;
  }

  .skufnya-promo__fallback {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    padding-top: var(--space-2);
  }

  .skufnya-promo__benefits {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .skufnya-promo__benefits li {
    padding: 0.4rem 0.85rem;
    border: var(--border-soft);
    border-radius: var(--radius-full);
    background: rgba(245, 237, 224, 0.66);
    color: var(--text-secondary);
    font-size: var(--fs-sm);
    line-height: 1.45;
  }

  /* 1024px: aligned with the site-wide breakpoint ladder (was 1100px) */
  @media (max-width: 1024px) {
    .skufnya-promo__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .skufnya-promo {
      padding: var(--space-8) 0;
    }

    .skufnya-promo__header,
    .skufnya-promo__fallback {
      align-items: flex-start;
      flex-direction: column;
    }

    .skufnya-promo__main-link,
    .skufnya-promo__fallback-link {
      width: 100%;
    }
  }

  /* 560px is content-driven: below it two promo cards no longer fit */
  @media (max-width: 560px) {
    .skufnya-promo__grid {
      grid-template-columns: 1fr;
    }
  }

  /* External promo has no value on paper */
  @media print {
    .skufnya-promo {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .skufnya-promo-card,
    .skufnya-promo-card__image {
      transition: none;
    }

    .skufnya-promo-card:hover {
      transform: none;
    }

    .skufnya-promo-card:hover .skufnya-promo-card__image {
      transform: none;
    }
  }
</style>
