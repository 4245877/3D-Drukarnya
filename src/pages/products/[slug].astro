---
import '../../styles/pages/product.css';
import Layout from '../../components/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProductGallery from '../../components/ProductGallery.astro';
import ProductPrice from '../../components/ProductPrice.astro';
import { getAllProducts } from '../../utils/products';
import type { Product } from '../../utils/products';
import { parseDescription } from '../../utils/description.mjs';
import { buildProductTitle } from '../../utils/seo.mjs';
import { truncate, toJsonLd } from '../../utils/text';

export function getStaticPaths() {
  return getAllProducts().map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

interface Props {
  product: Product;
}

const { product } = Astro.props as Props;

// Short SEO <title> (shared rules in src/utils/seo.mjs); the visible <h1>
// below keeps the full product title.
const pageTitle = buildProductTitle(product.title);

const META_DESCRIPTION_MAX = 160;
const META_DESCRIPTION_SUFFIX = 'FDM 3D-друк у Києві з PLA/PETG під замовлення.';

// The suffix carries the page's target keywords, so the lead has to be cut to
// fit around it — truncating the joined string instead would drop the suffix.
const pageDescription = product.shortDescription
  ? `${truncate(
      product.shortDescription,
      META_DESCRIPTION_MAX - META_DESCRIPTION_SUFFIX.length - 1,
    )} ${META_DESCRIPTION_SUFFIX}`
  : truncate(product.description, META_DESCRIPTION_MAX);

const site = Astro.site ?? new URL('https://4245877.github.io');
const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const absoluteBaseUrl = new URL(basePath, site);

const toImageUrl = (image: string) => {
  if (!image) return '';

  if (/^https?:\/\//i.test(image)) return image;
  if (/^\/\//.test(image)) return `https:${image}`;

  return new URL(image.replace(/^\/+/, ''), absoluteBaseUrl).toString();
};

const imageUrls = product.images.map(toImageUrl).filter(Boolean);
const hasImages = imageUrls.length > 0;
// When the product has no usable image, Layout falls back to the site's
// branded OG image on its own (empty string → default).
const ogImage = imageUrls[0] ?? '';

const productUrl = new URL(`products/${product.slug}/`, absoluteBaseUrl).toString();
const catalogUrl = absoluteBaseUrl.toString();
const sellerId = `${catalogUrl}#local-business`;
const logoUrl = new URL('apple-touch-icon.png', absoluteBaseUrl).toString();
const olxUrl = 'https://www.olx.ua/uk/list/user/15L7LS/';
const skufnyaUrl = 'https://www.skufnya.com/';
// Baked in at build time. Anchoring to the end of the build year would mark
// every Offer expired from 1 January until the next deploy, so roll a year on.
const priceValidUntil = new Date(Date.now() + 365 * 24 * 60 * 60 * 1000)
  .toISOString()
  .slice(0, 10);

// ── Price & availability: one typed source for the card, this page and the
// JSON-LD offer (see src/data/product.schema.mjs). ─────────────────────────
const isFromPrice = product.priceType === 'from';
const priceLabel = isFromPrice ? 'Ціна від' : 'Ціна';

const AVAILABILITY_SCHEMA_URL: Partial<Record<Product['availability'], string>> = {
  in_stock: 'https://schema.org/InStock',
  made_to_order: 'https://schema.org/MadeToOrder',
  unavailable: 'https://schema.org/OutOfStock',
};
const AVAILABILITY_VISIBLE_TEXT: Partial<Record<Product['availability'], string>> = {
  in_stock: 'В наявності',
  made_to_order: 'Виготовлення під замовлення',
  unavailable: 'Тимчасово недоступно',
};
// `unconfirmed` stays undefined in both maps: no availability is published
// and no status line is rendered until the status is confirmed.
const schemaAvailability = AVAILABILITY_SCHEMA_URL[product.availability];
const availabilityText = AVAILABILITY_VISIBLE_TEXT[product.availability];

// ── Order CTA. A validated per-product orderUrl (https, allow-listed host —
// enforced by the schema) wins; otherwise the shared OLX profile is used and
// the note says so honestly. ───────────────────────────────────────────────
const orderHref = product.orderUrl ?? olxUrl;
const hasDirectOrderUrl = Boolean(product.orderUrl);
const orderNote = hasDirectOrderUrl
  ? 'Посилання відкриває сторінку цього товару на OLX.'
  : 'Окремої сторінки товару на OLX немає: кнопка відкриває загальний профіль продавця. Напишіть у повідомленні, який саме виріб вас цікавить.';

const pageKeywords = [
  product.title,
  product.category,
  product.material,
  'FDM 3D-друк Київ',
  '3D друк на замовлення',
  'друк PLA Київ',
  'друк PETG Київ',
  'корпуси для електроніки',
  'прототипування Київ',
]
  .filter(Boolean)
  .join(', ');

// ── Description: paragraphs + simple "- " bullet lists, parsed by a pure
// utility (tested in tests/description.test.mjs) and rendered with regular
// escaping — no set:html anywhere near the raw text. ───────────────────────
const descriptionBlocks = parseDescription(product.description);
const introBlock =
  descriptionBlocks[0]?.type === 'paragraph' ? descriptionBlocks[0] : undefined;
const bodyBlocks = introBlock ? descriptionBlocks.slice(1) : descriptionBlocks;
const hasDescription = descriptionBlocks.length > 0;

const variants = product.variants ?? [];
const hasVariants = variants.length > 0;

const warnings = product.safetyWarnings ?? [];
const hasWarnings = warnings.length > 0;
const warningDefaultTitle = (level: 'notice' | 'critical') =>
  level === 'critical' ? 'Важливе попередження щодо безпеки' : 'Зверніть увагу';

const productFacts = [
  product.material ? { label: 'Матеріал', value: product.material } : null,
  product.leadTime ? { label: 'Термін виготовлення', value: product.leadTime } : null,
  product.category ? { label: 'Категорія', value: product.category } : null,
  hasVariants
    ? {
        label: 'Варіанти',
        value: product.variantSummary ?? `${variants.length} конфігурацій`,
      }
    : null,
].filter((item): item is { label: string; value: string } => Boolean(item));

const hasFacts = productFacts.length > 0;

const additionalProperties = [
  product.material
    ? {
        '@type': 'PropertyValue',
        name: 'Матеріал',
        value: product.material,
      }
    : null,
  product.leadTime
    ? {
        '@type': 'PropertyValue',
        name: 'Термін виготовлення',
        value: product.leadTime,
      }
    : null,
  hasVariants
    ? {
        '@type': 'PropertyValue',
        name: 'Варіанти',
        value: variants.map((variant) => variant.name).join(', '),
      }
    : null,
].filter(Boolean);

const seller = {
  '@type': 'LocalBusiness',
  '@id': sellerId,
  name: '3D Друкарня',
  url: catalogUrl,
  logo: logoUrl,
  sameAs: [olxUrl, skufnyaUrl],
};

const offerShared = {
  priceCurrency: 'UAH',
  priceValidUntil,
  ...(schemaAvailability ? { availability: schemaAvailability } : {}),
  itemCondition: 'https://schema.org/NewCondition',
  url: productUrl,
  eligibleRegion: {
    '@type': 'Country',
    name: 'UA',
  },
  seller,
};

// "Ціна від" publishes an AggregateOffer with only the confirmed minimum
// (lowPrice) — no invented highPrice and no exact Offer.price. All current
// "from" products genuinely aggregate several configurations (variants).
// publishOffer: false keeps the offer out of JSON-LD entirely.
const offers = !product.publishOffer
  ? undefined
  : isFromPrice
    ? { '@type': 'AggregateOffer', lowPrice: product.price, ...offerShared }
    : { '@type': 'Offer', price: product.price, ...offerShared };

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Product',
      '@id': `${productUrl}#product`,
      name: product.title,
      description: product.description,
      image: hasImages ? imageUrls : undefined,
      sku: product.slug,
      category: product.category,
      material: product.material,
      brand: {
        '@type': 'Brand',
        name: '3D Друкарня',
      },
      additionalProperty: additionalProperties.length > 0 ? additionalProperties : undefined,
      mainEntityOfPage: productUrl,
      offers,
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${productUrl}#breadcrumbs`,
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Каталог 3D-друку',
          item: catalogUrl,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: product.title,
          item: productUrl,
        },
      ],
    },
  ],
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={`/products/${product.slug}/`}
  image={ogImage}
  imageAlt={product.title}
  keywords={pageKeywords}
  ogType="product"
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={toJsonLd(structuredData)}
  ></script>

  <section class="product-page">
    <div class="container">
      <Breadcrumbs
        items={[
          { label: 'Каталог 3D-друку', href: import.meta.env.BASE_URL },
          { label: product.title },
        ]}
      />

      <div class="product-page__hero">
        {hasImages && (
          <section
            id="product-gallery"
            class="product-page__gallery-card"
            aria-label="Фотографії товару"
          >
            <ProductGallery title={product.title} images={imageUrls} />
          </section>
        )}

        <aside class="product-page__summary-card" aria-labelledby="product-title">
          <div class="product-page__header">
            <p class="product-page__eyebrow">{product.category ?? 'Товар'}</p>

            <h1 id="product-title" class="product-page__title">
              {product.title}
            </h1>

            {product.shortDescription && (
              <p class="product-page__lead">{product.shortDescription}</p>
            )}
          </div>

          <section
            id="product-price"
            class="product-page__price-card"
            aria-labelledby="product-price-title"
          >
            <p id="product-price-title" class="product-page__price-label">
              {priceLabel}
            </p>

            <div class="product-page__price">
              <ProductPrice amount={product.price} large={true} />
            </div>

            {availabilityText && (
              <p class="product-page__price-note product-page__availability">
                <strong>{availabilityText}</strong>
              </p>
            )}

            {product.leadTime && (
              <p class="product-page__price-note">
                Термін виготовлення: <strong>{product.leadTime}</strong>
              </p>
            )}

            {product.priceNote && (
              <p class="product-page__price-note">{product.priceNote}</p>
            )}
          </section>

          {hasWarnings && (
            <div class="product-page__warnings">
              {warnings.map((warning, index) => (
                <section
                  class:list={[
                    'product-warning',
                    { 'product-warning--critical': warning.level === 'critical' },
                  ]}
                  role="note"
                  aria-labelledby={`product-warning-title-${index}`}
                >
                  <p
                    id={`product-warning-title-${index}`}
                    class="product-warning__title"
                  >
                    <span class="product-warning__icon" aria-hidden="true">⚠</span>
                    <span class="product-warning__badge">
                      {warning.level === 'critical' ? 'Небезпека' : 'Увага'}
                    </span>
                    {warning.title ?? warningDefaultTitle(warning.level)}
                  </p>
                  <p class="product-warning__text">{warning.text}</p>
                </section>
              ))}
            </div>
          )}

          <div class="product-page__cta">
            <a
              class="btn btn--primary btn--lg product-page__cta-button"
              href={orderHref}
              target="_blank"
              rel="noopener noreferrer"
            >
              Замовити цей виріб
            </a>
            <p class="product-page__cta-note">{orderNote}</p>
          </div>

          {hasFacts && (
            <ul class="product-page__chips" role="list" aria-label="Ключові характеристики">
              {productFacts.map((fact) => (
                <li class="product-page__chip">
                  <span>{fact.label}:</span> {fact.value}
                </li>
              ))}
            </ul>
          )}

          <nav class="product-page__anchors" aria-label="Навігація по сторінці товару">
            <a href="#product-description">Опис</a>
            {hasVariants && <a href="#product-variants">Варіанти</a>}
            {hasFacts && <a href="#product-details">Характеристики</a>}
            <a href="#fdm-print-use-cases">FDM-друк</a>
            {hasImages && <a href="#product-gallery">Фото</a>}
          </nav>
        </aside>
      </div>

      <div class="product-page__sections">
        <section
          id="product-description"
          class="product-page__section-card"
          aria-labelledby="product-description-title"
        >
          <div class="product-page__section-head">
            <p class="kicker">Опис товару</p>
            <h2 id="product-description-title">Опис</h2>
          </div>

          {hasDescription ? (
            <>
              {introBlock && (
                <p class="product-page__description-intro">{introBlock.text}</p>
              )}

              {bodyBlocks.length > 0 && (
                <div class="product-page__description">
                  {bodyBlocks.map((block) =>
                    block.type === 'list' ? (
                      <ul class="product-page__description-list" role="list">
                        {block.items.map((item) => (
                          <li>{item}</li>
                        ))}
                      </ul>
                    ) : (
                      <p>{block.text}</p>
                    ),
                  )}
                </div>
              )}
            </>
          ) : (
            <p class="product-page__description-intro">
              Опис товару буде додано найближчим часом.
            </p>
          )}
        </section>

        {hasFacts && (
          <section
            id="product-details"
            class="product-page__section-card"
            aria-labelledby="product-details-title"
          >
            <div class="product-page__section-head">
              <p class="kicker">Деталі</p>
              <h2 id="product-details-title">Характеристики</h2>
            </div>

            <dl class="product-page__details">
              {productFacts.map((fact) => (
                <div class="product-page__details-item">
                  <dt>{fact.label}</dt>
                  <dd>{fact.value}</dd>
                </div>
              ))}
            </dl>
          </section>
        )}

        {hasVariants && (
          <section
            id="product-variants"
            class="product-page__section-card product-page__section-card--wide"
            aria-labelledby="product-variants-title"
          >
            <div class="product-page__section-head">
              <p class="kicker">Конфігурації</p>
              <h2 id="product-variants-title">Варіанти</h2>
            </div>

            <ul class="product-page__variants" role="list" aria-label="Варіанти товару">
              {variants.map((variant) => (
                <li class="product-page__variant">
                  <div class="product-page__variant-head">
                    <h3>{variant.name}</h3>
                    {variant.badge && <span>{variant.badge}</span>}
                  </div>

                  <p>{variant.description}</p>
                </li>
              ))}
            </ul>
          </section>
        )}

        <section
          id="fdm-print-use-cases"
          class="product-page__section-card product-page__section-card--wide"
          aria-labelledby="fdm-print-use-cases-title"
        >
          <div class="product-page__section-head">
            <p class="kicker">FDM-друк під замовлення</p>
            <h2 id="fdm-print-use-cases-title">Для корпусів, кріплень і прототипів</h2>
          </div>

          <p class="product-page__description-intro">
            Цей виріб друкується під замовлення методом FDM. Перед друком можна узгодити
            матеріал, колір, заповнення, міцність і невеликі зміни моделі під вашу задачу.
          </p>

          <ul class="product-page__use-list" role="list">
            <li>друк PLA або PETG залежно від температури, навантаження та умов використання;</li>
            <li>адаптація отворів, посадкових місць, товщини стінок або кольору;</li>
            <li>виготовлення корпусів для електроніки, кронштейнів, панелей і прототипів;</li>
            <li>самовивіз у Києві або відправлення OLX Доставкою по Україні.</li>
          </ul>
        </section>
      </div>
    </div>
  </section>
</Layout>
