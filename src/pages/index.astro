---
import Layout from '../components/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import SkufnyaPromo from '../components/SkufnyaPromo.astro';
import { getAllProducts } from '../utils/products';

import '../styles/pages/catalog.css';

const products = getAllProducts();

const title = 'FDM 3D-друк у Києві | 3D Друкарня';

const description =
  'FDM 3D-друк у Києві на замовлення: PLA, PETG, корпуси для електроніки, прототипи та дрібносерійні деталі. OLX Доставка.';

const keywords =
  '3D-друк Київ, FDM друк Київ, 3D друк на замовлення, друк PLA Київ, друк PETG Київ, друк корпусів для електроніки, прототипування Київ';

const olxUrl = 'https://www.olx.ua/uk/list/user/15L7LS/';
const skufnyaUrl = 'https://www.skufnya.com/';
const site = Astro.site ?? new URL('https://4245877.github.io');
const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const absoluteBaseUrl = new URL(basePath, site);
const homepageUrl = absoluteBaseUrl.toString();

const toAbsoluteUrl = (value: string) => {
  if (/^https?:\/\//i.test(value)) return value;
  if (/^\/\//.test(value)) return `https:${value}`;

  return new URL(value.replace(/^\/+/, ''), absoluteBaseUrl).toString();
};

const logoUrl = toAbsoluteUrl('/apple-touch-icon.png');
const ogImageUrl = toAbsoluteUrl('/OGimage.png');

const catalogSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${homepageUrl}#website`,
      name: '3D Друкарня',
      alternateName: ['FDM 3D-друк у Києві', '3D-друк Київ'],
      url: homepageUrl,
      inLanguage: 'uk-UA',
      description,
    },
    {
      '@type': 'LocalBusiness',
      '@id': `${homepageUrl}#local-business`,
      name: '3D Друкарня',
      url: homepageUrl,
      description,
      image: ogImageUrl,
      logo: {
        '@type': 'ImageObject',
        url: logoUrl,
        width: 180,
        height: 180,
      },
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Київ',
        addressCountry: 'UA',
      },
      areaServed: [
        { '@type': 'City', name: 'Київ' },
        { '@type': 'Country', name: 'Україна' },
      ],
      priceRange: '₴₴',
      sameAs: [olxUrl, skufnyaUrl],
      knowsAbout: [
        'FDM 3D-друк',
        '3D-друк Київ',
        '3D друк на замовлення',
        'PLA',
        'PETG',
        'корпуси для електроніки',
        'прототипування',
      ],
    },
    {
      '@type': 'Service',
      '@id': `${homepageUrl}#fdm-printing-service`,
      name: 'FDM 3D-друк у Києві',
      serviceType: 'FDM 3D-друк на замовлення',
      provider: { '@id': `${homepageUrl}#local-business` },
      areaServed: { '@type': 'City', name: 'Київ' },
      description,
      offers: {
        '@type': 'Offer',
        url: homepageUrl,
        priceCurrency: 'UAH',
        availability: 'https://schema.org/InStock',
      },
    },
    {
      '@type': 'FAQPage',
      '@id': `${homepageUrl}#faq`,
      mainEntity: [
        {
          '@type': 'Question',
          name: 'З яких матеріалів можна замовити FDM 3D-друк у Києві?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Для більшості замовлень підходять PLA та PETG. PLA зручний для прототипів і декоративних деталей, PETG краще підходить для функціональних деталей, кріплень і корпусів.',
          },
        },
        {
          '@type': 'Question',
          name: 'Чи можна надрукувати корпус для електроніки?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Так, можна замовити друк корпусів для електроніки, кронштейнів, панелей, адаптерів і прототипів з урахуванням розмірів плати, розʼємів та отворів під кріплення.',
          },
        },
        {
          '@type': 'Question',
          name: 'Як передати модель для 3D-друку?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Найзручніше надати STL, 3MF або STEP-файл. Якщо є тільки ідея чи ескіз, можна обговорити підготовку або адаптацію моделі перед друком.',
          },
        },
      ],
    },
  ],
};
---

<Layout
  title={title}
  description={description}
  canonicalPath="/"
  keywords={keywords}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(catalogSchema)}
  ></script>

  <div class="catalog-page">
    <section class="catalog-hero">
      <div class="container">
        <div class="catalog-hero__inner">
          <div class="catalog-hero__left">
            <p class="catalog-hero__eyebrow">FDM 3D-друк Київ</p>

            <h1 class="catalog-hero__title">
              FDM <span class="highlight">3D-друк</span> у Києві
            </h1>

            <p class="catalog-hero__subtitle">
              Друк на замовлення з PLA та PETG: корпуси для електроніки, прототипи,
              кріплення, адаптери й невеликі серії. Можливий самовивіз у Києві або
              OLX Доставка по Україні.
            </p>

            <div class="catalog-hero__stats">
              <div class="catalog-hero__stat-pill">
                <span class="catalog-hero__stat-pill-value">{products.length}</span>
                <span class="catalog-hero__stat-pill-label">прикладів друку</span>
              </div>

              <div class="catalog-hero__stat-pill">
                <span class="catalog-hero__stat-pill-value">PLA/PETG</span>
                <span class="catalog-hero__stat-pill-label">матеріали</span>
              </div>

              <div class="catalog-hero__stat-pill">
                <span class="catalog-hero__stat-pill-value">1–3</span>
                <span class="catalog-hero__stat-pill-label">дні на типове замовлення</span>
              </div>

              <div class="catalog-hero__stat-pill">
                <span class="catalog-hero__stat-pill-value">Київ</span>
                <span class="catalog-hero__stat-pill-label">самовивіз</span>
              </div>

              <a
                class="catalog-hero__stat-pill catalog-hero__stat-pill--link"
                href={olxUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="catalog-hero__stat-pill-value">OLX</span>
                <span class="catalog-hero__stat-pill-label">профіль OLX</span>
              </a>
            </div>
          </div>

          <div class="catalog-hero__aside" aria-hidden="true">
            <div class="catalog-hero__emblem">
              <svg viewBox="0 0 200 236" role="presentation" focusable="false">
                <defs>
                  <linearGradient id="heroShield" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0" stop-color="#8E3F43" />
                    <stop offset="0.55" stop-color="#AC4151" />
                    <stop offset="1" stop-color="#C88463" />
                  </linearGradient>
                  <radialGradient id="heroCore" cx="0.5" cy="0.42" r="0.6">
                    <stop offset="0" stop-color="#E8D8BE" stop-opacity="0.95" />
                    <stop offset="1" stop-color="#E8D8BE" stop-opacity="0" />
                  </radialGradient>
                  <clipPath id="heroShieldClip">
                    <path d="M100 16 C130 32 158 36 178 40 C178 96 176 164 100 220 C24 164 22 96 22 40 C42 36 70 32 100 16 Z" />
                  </clipPath>
                </defs>

                <path
                  d="M100 16 C130 32 158 36 178 40 C178 96 176 164 100 220 C24 164 22 96 22 40 C42 36 70 32 100 16 Z"
                  fill="url(#heroShield)"
                />

                <g clip-path="url(#heroShieldClip)" fill="none" stroke="#E8D8BE" stroke-linecap="round">
                  <circle cx="100" cy="120" r="54" stroke-opacity="0.16" stroke-width="12" />
                  <circle cx="100" cy="120" r="36" stroke-opacity="0.26" stroke-width="10" />
                </g>

                <circle cx="100" cy="120" r="18" fill="url(#heroCore)" />

                <path
                  d="M100 30 C126 44 150 48 167 52 C167 100 165 158 100 205 C35 158 33 100 33 52 C50 48 74 44 100 30 Z"
                  fill="none"
                  stroke="#E8D8BE"
                  stroke-opacity="0.32"
                  stroke-width="2"
                />

                <path
                  class="emblem-spark"
                  d="M150 58 l3.2 9.4 9.4 3.2 -9.4 3.2 -3.2 9.4 -3.2 -9.4 -9.4 -3.2 9.4 -3.2 z"
                  fill="#E8D8BE"
                  fill-opacity="0.9"
                />
                <path
                  class="emblem-spark emblem-spark--sm"
                  d="M60 84 l2.2 6.4 6.4 2.2 -6.4 2.2 -2.2 6.4 -2.2 -6.4 -6.4 -2.2 6.4 -2.2 z"
                  fill="#E8D8BE"
                  fill-opacity="0.75"
                />
              </svg>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section aria-labelledby="print-examples-title">
      <div class="container">
        <h2 id="print-examples-title" class="sr-only">Приклади FDM 3D-друку</h2>

        <div class="catalog-controls">
          <div class="catalog-controls__left">
            <p class="catalog-results-count">
              На сторінці <strong>{products.length}</strong> прикладів друку з окремими описами.
            </p>
          </div>
        </div>

        <div class="catalog-layout">
          <aside class="catalog-sidebar">
            <div class="catalog-filter-section is-open">
              <div class="catalog-filter-section__head">
                <span class="catalog-filter-section__label">Про FDM друк</span>
              </div>

              <div class="catalog-filter-section__body">
                <div class="catalog-filter-section__inner">
                  <p class="catalog-results-count">
                    Друк деталей під замовлення для ремонту, прототипування, електроніки,
                    майстерні та невеликих серій.
                  </p>
                </div>
              </div>
            </div>

            <div class="catalog-filter-section is-open">
              <div class="catalog-filter-section__head">
                <span class="catalog-filter-section__label">Напрями</span>
              </div>

              <div class="catalog-filter-section__body">
                <div class="catalog-filter-section__inner">
                  <ul class="catalog-tag-list">
                    <li class="tag tag--copper">PLA</li>
                    <li class="tag tag--copper">PETG</li>
                    <li class="tag tag--copper">Корпуси</li>
                    <li class="tag tag--copper">Прототипи</li>
                  </ul>
                </div>
              </div>
            </div>
          </aside>

          <div class="catalog-content">
            {
              products.length > 0 ? (
                <div class="catalog-grid">
                  {products.map((product) => <ProductCard product={product} />)}
                </div>
              ) : (
                <div class="catalog-no-results">
                  <div class="catalog-no-results__art">∅</div>
                  <h2 class="catalog-no-results__title">Приклади поки що не додані</h2>
                  <p class="catalog-no-results__text">
                    Додай перший приклад у джерело даних, і він зʼявиться тут автоматично.
                  </p>
                </div>
              )
            }
          </div>
        </div>
      </div>
    </section>

    <SkufnyaPromo />

    <section class="catalog-seo" aria-labelledby="services-title">
      <div class="container">
        <div class="catalog-seo__intro">
          <p class="catalog-seo__eyebrow">Послуги</p>
          <h2 id="services-title">Послуги FDM 3D-друку в Києві</h2>
          <p>
            3D-друк на замовлення підходить, коли потрібна одна функціональна деталь,
            невелика партія або швидкий прототип перед запуском виробу. Можна надрукувати
            готову STL/3MF-модель, перевірити посадку деталі, адаптувати корпус під плату
            або зробити кріплення під конкретні розміри.
          </p>
        </div>

        <div class="catalog-seo__grid">
          <article class="catalog-seo__item">
            <h3>3D-друк на замовлення</h3>
            <p>
              FDM друк у Києві для побутових, технічних і робочих задач: адаптери,
              тримачі, кронштейни, кришки, вставки, органайзери та запасні пластикові
              деталі, які складно швидко купити готовими.
            </p>
          </article>

          <article class="catalog-seo__item">
            <h3>Корпуси для електроніки</h3>
            <p>
              Друк корпусів для електроніки з отворами під розʼєми, вентиляцію, кнопки
              та кріплення. Такий формат зручний для плат, контролерів, датчиків,
              блоків живлення, DIY-пристроїв і майстерні.
            </p>
          </article>

          <article class="catalog-seo__item">
            <h3>Прототипування</h3>
            <p>
              Прототипування в Києві допомагає швидко перевірити форму, ергономіку,
              габарити й сумісність деталі перед фінальним виробництвом або замовленням
              дорожчого матеріалу.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="catalog-seo" aria-labelledby="materials-title">
      <div class="container">
        <div class="catalog-seo__intro">
          <p class="catalog-seo__eyebrow">Матеріали</p>
          <h2 id="materials-title">Друк PLA та PETG</h2>
          <p>
            Для FDM-друку найчастіше використовуються PLA і PETG. Матеріал підбирається
            під задачу: зовнішній вигляд, жорсткість, температуру використання, навантаження
            та умови експлуатації готової деталі.
          </p>
        </div>

        <div class="catalog-seo__grid">
          <article class="catalog-seo__item">
            <h3>PLA</h3>
            <p>
              Друк PLA у Києві добре підходить для прототипів, декоративних деталей,
              макетів, органайзерів і корпусів, які не працюють біля джерел тепла.
            </p>
          </article>

          <article class="catalog-seo__item">
            <h3>PETG</h3>
            <p>
              Друк PETG у Києві варто обирати для функціональних деталей, кріплень,
              корпусів і виробів, яким потрібна краща ударостійкість та стійкість до
              підвищеної температури.
            </p>
          </article>

          <article class="catalog-seo__item">
            <h3>Підбір параметрів</h3>
            <p>
              Для замовлення можна узгодити колір, заповнення, товщину стінок, орієнтацію
              друку та потрібну міцність. Це важливо для деталей, які мають не лише
              виглядати акуратно, а й нормально працювати в збірці.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="catalog-faq" aria-labelledby="order-title">
      <div class="container">
        <div class="catalog-faq__inner">
          <h2 id="order-title">Строки, ціни, доставка і контакти</h2>

          <div class="catalog-faq__list">
            <article class="catalog-faq__item">
              <h3>Строки виготовлення</h3>
              <p>
                Типові замовлення друкуються за 1–3 дні після узгодження моделі, матеріалу
                та кольору. Великі деталі або партії оцінюються окремо за часом друку.
              </p>
            </article>

            <article class="catalog-faq__item">
              <h3>Ціни</h3>
              <p>
                Вартість залежить від матеріалу, ваги, часу друку, складності моделі та
                потреби в адаптації. Для готових прикладів ціна вказана на окремих сторінках.
              </p>
            </article>

            <article class="catalog-faq__item">
              <h3>Доставка</h3>
              <p>
                У Києві можливий самовивіз. По Україні доступна OLX Доставка, якщо замовлення
                підходить за розміром і умовами відправлення.
              </p>
            </article>

            <article class="catalog-faq__item">
              <h3>Контакти</h3>
              <p>
                Для замовлення надішліть модель, опис задачі або посилання на потрібну деталь
                через OLX-профіль. Бажано одразу вказати матеріал, колір, кількість і вимоги
                до міцності.
              </p>
            </article>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
