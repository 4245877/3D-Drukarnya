---
import Layout from '../components/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { getAllProducts } from '../utils/products';

import '../styles/pages/catalog.css';

const products = getAllProducts();

const title =
  'HomeLab магазин | NAS корпуси, mini rack і серверні аксесуари';

const description =
  'Каталог товарів для HomeLab: 3D-друковані NAS корпуси, mini rack, серверні стійки, панелі Synology, аксесуари для Raspberry Pi, mini-PC і мережевого обладнання.';

const keywords =
  'HomeLab магазин, homelab Україна, обладнання для домашньої лабораторії, домашній сервер, серверна стійка, mini rack, NAS корпус, корпус для NAS, мережеве обладнання, Raspberry Pi rack, Lenovo ThinkCentre NAS, Synology rack, 3D друк серверних корпусів';

const olxUrl = 'https://www.olx.ua/uk/list/user/15L7LS/';
const site = Astro.site ?? new URL('https://4245877.github.io');
const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const absoluteBaseUrl = new URL(basePath, site);
const homepageUrl = absoluteBaseUrl.toString();

const toAbsoluteUrl = (value: string) => {
  if (/^https?:\/\//i.test(value)) return value;
  if (/^\/\//.test(value)) return `https:${value}`;

  return new URL(value.replace(/^\/+/, ''), absoluteBaseUrl).toString();
};

const catalogSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${homepageUrl}#website`,
      name: '3D Друкарня HomeLab',
      alternateName: ['HomeLab магазин', '3D Друкарня'],
      url: homepageUrl,
      inLanguage: 'uk-UA',
      description,
    },
    {
      '@type': 'Store',
      '@id': `${homepageUrl}#store`,
      name: '3D Друкарня HomeLab',
      url: homepageUrl,
      description,
      areaServed: ['UA', 'Україна'],
      sameAs: [olxUrl],
      knowsAbout: [
        'HomeLab',
        'домашні сервери',
        'NAS корпуси',
        'mini rack',
        'серверні стійки',
        'мережеве обладнання',
        '3D друк серверних аксесуарів',
      ],
    },
    {
      '@type': 'ItemList',
      '@id': `${homepageUrl}#catalog`,
      name: 'Каталог товарів для HomeLab',
      itemListElement: products.map((product, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        url: new URL(`products/${product.slug}/`, absoluteBaseUrl).toString(),
        item: {
          '@type': 'Product',
          name: product.title,
          description: product.shortDescription,
          image: product.images[0] ? toAbsoluteUrl(product.images[0]) : undefined,
          category: product.category,
          offers: {
            '@type': 'Offer',
            price: product.price,
            priceCurrency: 'UAH',
            availability: 'https://schema.org/InStock',
          },
        },
      })),
    },
    {
      '@type': 'FAQPage',
      '@id': `${homepageUrl}#faq`,
      mainEntity: [
        {
          '@type': 'Question',
          name: 'Яке обладнання підходить для домашньої лабораторії HomeLab?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Для HomeLab часто використовують mini-PC, Raspberry Pi, NAS, комутатори, роутери, патч-панелі, 10-дюймові mini rack стійки та корпуси для компактних серверів.',
          },
        },
        {
          '@type': 'Question',
          name: 'Чи можна замовити 3D-друкований корпус або стійку під свою конфігурацію?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Так, 3D-друк дозволяє адаптувати корпуси, панелі, кріплення й стійки під конкретний mini-PC, NAS, мережеве обладнання або серверну збірку.',
          },
        },
      ],
    },
  ],
};
---

<Layout
  title={title}
  description={description}
  canonicalPath="/"
  keywords={keywords}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(catalogSchema)}
  ></script>

  <div class="catalog-page">
    <section class="catalog-hero">
      <div class="container">
        <div class="catalog-hero__inner">
          <div class="catalog-hero__left">
            <p class="catalog-hero__eyebrow">HomeLab магазин</p>

            <h1 class="catalog-hero__title">
              Обладнання для <span class="highlight">HomeLab</span>, NAS і домашніх серверів
            </h1>

            <p class="catalog-hero__subtitle">
              Каталог 3D-друкованих корпусів, mini rack стійок, панелей і кріплень для
              Raspberry Pi, mini-PC, Synology, Lenovo ThinkCentre, NAS та мережевого обладнання.
            </p>

            <div class="catalog-hero__stats">
              <div class="catalog-hero__stat-pill">
                <span class="catalog-hero__stat-pill-value">{products.length}</span>
                <span class="catalog-hero__stat-pill-label">товарів</span>
              </div>

              <div class="catalog-hero__stat-pill">
                <span class="catalog-hero__stat-pill-value">2–10</span>
                <span class="catalog-hero__stat-pill-label">фото на товар</span>
              </div>

              <div class="catalog-hero__stat-pill">
                <span class="catalog-hero__stat-pill-value">NAS</span>
                <span class="catalog-hero__stat-pill-label">корпуси</span>
              </div>

              <div class="catalog-hero__stat-pill">
                <span class="catalog-hero__stat-pill-value">10"</span>
                <span class="catalog-hero__stat-pill-label">mini rack</span>
              </div>

              <a
                class="catalog-hero__stat-pill catalog-hero__stat-pill--link"
                href={olxUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="catalog-hero__stat-pill-value">OLX</span>
                <span class="catalog-hero__stat-pill-label">профіль OLX</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section>
      <div class="container">
        <div class="catalog-controls">
          <div class="catalog-controls__left">
            <p class="catalog-results-count">
              У каталозі <strong>{products.length}</strong> товарів з окремими сторінками.
            </p>
          </div>
        </div>

        <div class="catalog-layout">
          <aside class="catalog-sidebar">
            <div class="catalog-filter-section is-open">
              <div class="catalog-filter-section__head">
                <span class="catalog-filter-section__label">Про HomeLab каталог</span>
              </div>

              <div class="catalog-filter-section__body">
                <div class="catalog-filter-section__inner">
                  <p class="catalog-results-count">
                    Товари підібрані для домашніх серверів, NAS, compact rack, mini-PC і мережевої інфраструктури.
                  </p>
                </div>
              </div>
            </div>

            <div class="catalog-filter-section is-open">
              <div class="catalog-filter-section__head">
                <span class="catalog-filter-section__label">Переваги</span>
              </div>

              <div class="catalog-filter-section__body">
                <div class="catalog-filter-section__inner">
                  <div class="catalog-pill-grid">
                    <span class="catalog-pill-option is-selected">Окремі сторінки</span>
                    <span class="catalog-pill-option is-selected">NAS корпуси</span>
                    <span class="catalog-pill-option is-selected">Mini rack</span>
                    <span class="catalog-pill-option is-selected">Під замовлення</span>
                  </div>
                </div>
              </div>
            </div>
          </aside>

          <div class="catalog-content">
            {
              products.length > 0 ? (
                <div class="catalog-grid">
                  {products.map((product) => <ProductCard product={product} />)}
                </div>
              ) : (
                <div class="catalog-no-results">
                  <div class="catalog-no-results__art">∅</div>
                  <h2 class="catalog-no-results__title">Каталог поки що порожній</h2>
                  <p class="catalog-no-results__text">
                    Додай перший товар у джерело даних, і він з’явиться тут автоматично.
                  </p>
                </div>
              )
            }
          </div>
        </div>
      </div>
    </section>

    <section class="catalog-seo" aria-labelledby="homelab-catalog-title">
      <div class="container">
        <div class="catalog-seo__intro">
          <p class="catalog-seo__eyebrow">Домашня лабораторія</p>
          <h2 id="homelab-catalog-title">
            HomeLab обладнання для компактного сервера, NAS і мережевої полиці
          </h2>
          <p>
            Каталог зібраний для тих, хто будує домашню лабораторію: файловий сервер,
            NAS, медіасервер, Proxmox-вузол, TrueNAS-сховище або акуратну мережеву
            полицю з комутатором, роутером і патч-панеллю. Тут є 3D-друковані корпуси,
            стійки, фронтальні панелі та аксесуари, які допомагають розмістити
            обладнання компактно й обслуговувати його без хаосу з кабелями.
          </p>
        </div>

        <div class="catalog-seo__grid">
          <article class="catalog-seo__item">
            <h3>NAS корпуси та домашні сервери</h3>
            <p>
              Корпуси для NAS на базі Mini-ITX, Intel NUC, Lenovo ThinkCentre Tiny,
              Synology і compact PC. Підійдуть для файлового сервера, резервних копій,
              Plex, Jellyfin, TrueNAS, Proxmox та інших HomeLab-сценаріїв.
            </p>
          </article>

          <article class="catalog-seo__item">
            <h3>Mini rack і серверні стійки</h3>
            <p>
              10-дюймові mini rack стійки, модульні полиці, панелі та кріплення для
              Raspberry Pi, mini-PC, роутерів, комутаторів, keystone-модулів і
              патч-панелей.
            </p>
          </article>

          <article class="catalog-seo__item">
            <h3>3D-друк під конфігурацію</h3>
            <p>
              Якщо потрібна інша висота, колір, посадкове місце, отвір під порт або
              адаптація під конкретне мережеве обладнання, деталь можна надрукувати
              чи доопрацювати під вашу домашню лабораторію.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="catalog-faq" aria-labelledby="homelab-faq-title">
      <div class="container">
        <div class="catalog-faq__inner">
          <h2 id="homelab-faq-title">Питання про HomeLab товари</h2>

          <div class="catalog-faq__list">
            <article class="catalog-faq__item">
              <h3>Що можна зібрати на базі цих товарів?</h3>
              <p>
                Домашній NAS, файловий сервер, компактний Proxmox або TrueNAS вузол,
                медіасервер, мережеву полицю, mini rack для Raspberry Pi, комутатора,
                роутера та патч-панелі.
              </p>
            </article>

            <article class="catalog-faq__item">
              <h3>Чи входить електроніка в комплект?</h3>
              <p>
                Зазвичай у комплект входять 3D-друковані пластикові деталі. Диски,
                плати, блоки живлення, вентилятори, кабелі та інше обладнання
                докуповуються окремо, якщо це не зазначено в описі конкретного товару.
              </p>
            </article>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
