---
import Layout from '../components/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import SkufnyaPromo from '../components/SkufnyaPromo.astro';
import { getAllProducts } from '../utils/products';
import { toJsonLd } from '../utils/text';

import '../styles/pages/catalog.css';

const products = getAllProducts();

const title = 'FDM 3D-друк у Києві | 3D Друкарня';

const description =
  'FDM 3D-друк у Києві на замовлення: PLA, PETG, корпуси для електроніки, прототипи та дрібносерійні деталі. OLX Доставка.';

const keywords =
  '3D-друк Київ, FDM друк Київ, 3D друк на замовлення, друк PLA Київ, друк PETG Київ, друк корпусів для електроніки, прототипування Київ';

const olxUrl = 'https://www.olx.ua/uk/list/user/15L7LS/';
const skufnyaUrl = 'https://www.skufnya.com/';
const site = Astro.site ?? new URL('https://4245877.github.io');
const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const absoluteBaseUrl = new URL(basePath, site);
const homepageUrl = absoluteBaseUrl.toString();

const toAbsoluteUrl = (value: string) => {
  if (/^https?:\/\//i.test(value)) return value;
  if (/^\/\//.test(value)) return `https:${value}`;

  return new URL(value.replace(/^\/+/, ''), absoluteBaseUrl).toString();
};

const logoUrl = toAbsoluteUrl('/apple-touch-icon.png');
const ogImageUrl = toAbsoluteUrl('/OGimage.png');

const catalogSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${homepageUrl}#website`,
      name: '3D Друкарня',
      alternateName: ['FDM 3D-друк у Києві', '3D-друк Київ'],
      url: homepageUrl,
      inLanguage: 'uk-UA',
      description,
    },
    {
      '@type': 'LocalBusiness',
      '@id': `${homepageUrl}#local-business`,
      name: '3D Друкарня',
      url: homepageUrl,
      description,
      image: ogImageUrl,
      logo: {
        '@type': 'ImageObject',
        url: logoUrl,
        width: 180,
        height: 180,
      },
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Київ',
        addressCountry: 'UA',
      },
      areaServed: [
        { '@type': 'City', name: 'Київ' },
        { '@type': 'Country', name: 'Україна' },
      ],
      priceRange: '₴₴',
      sameAs: [olxUrl, skufnyaUrl],
      knowsAbout: [
        'FDM 3D-друк',
        '3D-друк Київ',
        '3D друк на замовлення',
        'PLA',
        'PETG',
        'корпуси для електроніки',
        'прототипування',
      ],
    },
    {
      '@type': 'Service',
      '@id': `${homepageUrl}#fdm-printing-service`,
      name: 'FDM 3D-друк у Києві',
      serviceType: 'FDM 3D-друк на замовлення',
      provider: { '@id': `${homepageUrl}#local-business` },
      areaServed: { '@type': 'City', name: 'Київ' },
      description,
      offers: {
        '@type': 'Offer',
        url: homepageUrl,
        priceCurrency: 'UAH',
        availability: 'https://schema.org/InStock',
      },
    },
    {
      '@type': 'FAQPage',
      '@id': `${homepageUrl}#faq`,
      mainEntity: [
        {
          '@type': 'Question',
          name: 'З яких матеріалів можна замовити FDM 3D-друк у Києві?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Для більшості замовлень підходять PLA та PETG. PLA зручний для прототипів і декоративних деталей, PETG краще підходить для функціональних деталей, кріплень і корпусів.',
          },
        },
        {
          '@type': 'Question',
          name: 'Чи можна надрукувати корпус для електроніки?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Так, можна замовити друк корпусів для електроніки, кронштейнів, панелей, адаптерів і прототипів з урахуванням розмірів плати, розʼємів та отворів під кріплення.',
          },
        },
        {
          '@type': 'Question',
          name: 'Як передати модель для 3D-друку?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Найзручніше надати STL, 3MF або STEP-файл. Якщо є тільки ідея чи ескіз, можна обговорити підготовку або адаптацію моделі перед друком.',
          },
        },
      ],
    },
  ],
};
---

<Layout
  title={title}
  description={description}
  canonicalPath="/"
  keywords={keywords}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={toJsonLd(catalogSchema)}
  ></script>

  <div class="catalog-page">
    <section class="catalog-hero">
      <div class="container">
        <div class="catalog-hero__inner">
          <div class="catalog-hero__left">
            <p class="catalog-hero__eyebrow">FDM 3D-друк Київ</p>

            <h1 class="catalog-hero__title">
              FDM <span class="highlight">3D-друк</span> у Києві
            </h1>

            <p class="catalog-hero__subtitle">
              Друк на замовлення з PLA та PETG: корпуси для електроніки, прототипи,
              кріплення, адаптери й невеликі серії. Можливий самовивіз у Києві або
              OLX Доставка по Україні.
            </p>

            <div class="catalog-hero__stats">
              <div class="catalog-hero__stat-pill">
                <span class="catalog-hero__stat-pill-value">{products.length}</span>
                <span class="catalog-hero__stat-pill-label">прикладів друку</span>
              </div>

              <div class="catalog-hero__stat-pill">
                <span class="catalog-hero__stat-pill-value">PLA/PETG</span>
                <span class="catalog-hero__stat-pill-label">матеріали</span>
              </div>

              <div class="catalog-hero__stat-pill">
                <span class="catalog-hero__stat-pill-value">1–3</span>
                <span class="catalog-hero__stat-pill-label">дні на типове замовлення</span>
              </div>

              <div class="catalog-hero__stat-pill">
                <span class="catalog-hero__stat-pill-value">Київ</span>
                <span class="catalog-hero__stat-pill-label">самовивіз</span>
              </div>

              <a
                class="catalog-hero__stat-pill catalog-hero__stat-pill--link"
                href={olxUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="catalog-hero__stat-pill-value">OLX</span>
                <span class="catalog-hero__stat-pill-label">профіль OLX</span>
              </a>
            </div>
          </div>

          <div class="catalog-hero__aside" aria-hidden="true">
            <div class="catalog-hero__rack">
              <!--
                Isometric open 10" home-lab rack (5U): patch panel, switch,
                mini-PC on a printed shelf, 4-bay NAS. 2:1 isometric grid:
                front-plane lines slope dy = +dx/2, side-plane dy = -dx/2.
                Printed parts (frame, rail, shelf, feet) = burgundy/copper,
                equipment = graphite/steel, highlights = cream, LEDs = warm.
              -->
              <svg viewBox="0 0 400 300" role="presentation" focusable="false">
                <defs>
                  <linearGradient id="hlr-print-front" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0" stop-color="#A64B52" />
                    <stop offset="0.55" stop-color="#8E3F43" />
                    <stop offset="1" stop-color="#6F3036" />
                  </linearGradient>
                  <linearGradient id="hlr-print-side" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0" stop-color="#78333A" />
                    <stop offset="1" stop-color="#54262C" />
                  </linearGradient>
                  <linearGradient id="hlr-print-top" x1="0" y1="0" x2="1" y2="0.5">
                    <stop offset="0" stop-color="#D99A74" />
                    <stop offset="1" stop-color="#BC7551" />
                  </linearGradient>
                  <linearGradient id="hlr-gear-front" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0" stop-color="#545B66" />
                    <stop offset="1" stop-color="#3A414B" />
                  </linearGradient>
                  <linearGradient id="hlr-tray-front" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0" stop-color="#5A616C" />
                    <stop offset="1" stop-color="#434A55" />
                  </linearGradient>
                  <linearGradient id="hlr-shelf-front" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0" stop-color="#D2916B" />
                    <stop offset="1" stop-color="#AC5F45" />
                  </linearGradient>
                  <linearGradient id="hlr-sheen-grad" x1="0" y1="0" x2="1" y2="0">
                    <stop offset="0" stop-color="#E8D8BE" stop-opacity="0" />
                    <stop offset="0.5" stop-color="#E8D8BE" stop-opacity="0.07" />
                    <stop offset="1" stop-color="#E8D8BE" stop-opacity="0" />
                  </linearGradient>
                  <clipPath id="hlr-front-clip">
                    <path d="M105 42 L229 104 L229 272 L105 210 Z" />
                  </clipPath>
                  <clipPath id="hlr-bay-clip">
                    <path d="M131 99 L231 149 L231 179 L131 129 Z" />
                  </clipPath>
                  <filter id="hlr-shadow-blur" x="-25%" y="-40%" width="150%" height="180%">
                    <feGaussianBlur stdDeviation="5" />
                  </filter>
                </defs>

                <!-- Ground shadow hugging the footprint -->
                <path class="rack-shadow" d="M94 218 L229 285 L306 247 L171 180 Z" fill="#160B06" opacity="0.36" filter="url(#hlr-shadow-blur)" />

                <!-- Printed rubber-like feet -->
                <g class="rack-feet" fill="#4A2226">
                  <rect x="100" y="208" width="12" height="8" rx="2" />
                  <rect x="223" y="270" width="12" height="8" rx="2" />
                  <rect x="289" y="237" width="12" height="8" rx="2" />
                </g>

                <!-- Printed base slab (floor of the frame) -->
                <g class="rack-base">
                  <path d="M105 198 L229 260 L295 227 L171 165 Z" fill="url(#hlr-print-top)" />
                  <path d="M105 210 L229 272 L229 260 L105 198 Z" fill="url(#hlr-print-front)" />
                  <path d="M229 272 L295 239 L295 227 L229 260 Z" fill="url(#hlr-print-side)" />
                </g>

                <!-- Dark interior behind the equipment -->
                <g class="rack-interior">
                  <path d="M125 52 L231 105 L231 249 L125 196 Z" fill="#17100C" />
                  <path d="M231 105 L283 79 L283 223 L231 249 Z" fill="#120C09" />
                </g>

                <!-- Equipment stack (top to bottom) -->
                <g class="rack-gear">
                  <!-- 1U patch panel -->
                  <g class="gear-patch">
                    <path d="M131 57 L231 107 L241 102 L141 52 Z" fill="#4A515B" />
                    <path d="M131 57 L231 107 L231 125 L131 75 Z" fill="url(#hlr-gear-front)" />
                    <path d="M231 107 L281 82 L281 100 L231 125 Z" fill="#2B3037" />
                    <path d="M131 57 L231 107" stroke="#E8D8BE" stroke-opacity="0.2" stroke-width="1" fill="none" />
                    <g fill="#15100D">
                      <path d="M139 74 L149 79 L149 71 L139 66 Z" />
                      <path d="M153 81 L163 86 L163 78 L153 73 Z" />
                      <path d="M167 88 L177 93 L177 85 L167 80 Z" />
                      <path d="M181 95 L191 100 L191 92 L181 87 Z" />
                      <path d="M195 102 L205 107 L205 99 L195 94 Z" />
                      <path d="M209 109 L219 114 L219 106 L209 101 Z" />
                    </g>
                    <path d="M154 80 L162 84 L162 76 L154 72 Z" fill="#C88463" />
                  </g>

                  <!-- 1U network switch -->
                  <g class="gear-switch">
                    <path d="M131 77 L231 127 L231 147 L131 97 Z" fill="url(#hlr-gear-front)" />
                    <path d="M231 127 L281 102 L281 122 L231 147 Z" fill="#2B3037" />
                    <path d="M131 77 L231 127" stroke="#E8D8BE" stroke-opacity="0.18" stroke-width="1" fill="none" />
                    <g fill="#15100D">
                      <path d="M139 95 L147 99 L147 92 L139 88 Z" />
                      <path d="M151 101 L159 105 L159 98 L151 94 Z" />
                      <path d="M163 107 L171 111 L171 104 L163 100 Z" />
                      <path d="M175 113 L183 117 L183 110 L175 106 Z" />
                    </g>
                    <path d="M175.5 112 L182.5 115.5 L182.5 109 L175.5 105.5 Z" fill="#C88463" />
                    <g class="rack-led">
                      <circle cx="203" cy="123" r="2.4" fill="#FFC98A" opacity="0.85" />
                    </g>
                    <g class="rack-led rack-led--blink-a">
                      <circle cx="212" cy="127.5" r="5" fill="#FFB25E" opacity="0.25" />
                      <circle cx="212" cy="127.5" r="2.5" fill="#FFC98A" />
                    </g>
                    <g class="rack-led">
                      <circle cx="221" cy="132" r="2.4" fill="#FFC98A" opacity="0.85" />
                    </g>
                  </g>

                  <!-- Mini-PC bay on a printed shelf -->
                  <g class="gear-bay">
                    <path d="M131 99 L231 149 L231 179 L131 129 Z" fill="#1B1511" />
                    <path d="M231 149 L281 124 L281 154 L231 179 Z" fill="#1A1E24" />
                    <g clip-path="url(#hlr-bay-clip)">
                      <path d="M131 123 L231 173 L241 168 L141 118 Z" fill="#D99A74" />
                      <path d="M139 110 L185 133 L201 125 L155 102 Z" fill="#59606B" />
                      <path d="M139 110 L185 133 L185 150 L139 127 Z" fill="url(#hlr-gear-front)" />
                      <path d="M185 133 L201 125 L201 142 L185 150 Z" fill="#2A2F36" />
                      <g fill="#15100D">
                        <path d="M146 129 L151 131.5 L151 126.5 L146 124 Z" />
                        <path d="M154 133 L159 135.5 L159 130.5 L154 128 Z" />
                      </g>
                      <g class="rack-led rack-led--blink-c">
                        <circle cx="177" cy="139" r="4.5" fill="#FFB25E" opacity="0.25" />
                        <circle cx="177" cy="139" r="2.3" fill="#FFC98A" />
                      </g>
                    </g>
                    <path d="M131 123 L231 173 L231 179 L131 129 Z" fill="url(#hlr-shelf-front)" />
                    <path d="M231 173 L281 148 L281 154 L231 179 Z" fill="#8F4A38" />
                    <path d="M131 125.5 L231 175.5" stroke="#5A2A20" stroke-opacity="0.3" stroke-width="1" fill="none" />
                  </g>

                  <!-- 2U NAS with four drive trays -->
                  <g class="gear-nas">
                    <path d="M131 131 L231 181 L231 243 L131 193 Z" fill="url(#hlr-gear-front)" />
                    <path d="M231 181 L281 156 L281 218 L231 243 Z" fill="#2B3037" />
                    <path d="M131 131 L231 181" stroke="#E8D8BE" stroke-opacity="0.18" stroke-width="1" fill="none" />
                    <path d="M241 182 L241 232 M249 178 L249 228 M257 174 L257 224" stroke="#E8D8BE" stroke-opacity="0.12" stroke-width="1.5" fill="none" />
                    <g fill="url(#hlr-tray-front)" stroke="#1E2126" stroke-width="1">
                      <path d="M137 139 L179 160 L179 184 L137 163 Z" />
                      <path d="M185 163 L227 184 L227 208 L185 187 Z" />
                      <path d="M137 167 L179 188 L179 212 L137 191 Z" />
                      <path d="M185 191 L227 212 L227 236 L185 215 Z" />
                    </g>
                    <path d="M141 160 L175 177 M189 184 L223 201 M141 188 L175 205 M189 212 L223 229" stroke="#1D2126" stroke-width="2" fill="none" stroke-linecap="round" />
                    <g class="rack-led rack-led--blink-b">
                      <circle cx="173" cy="161" r="4" fill="#FFB25E" opacity="0.25" />
                      <circle cx="173" cy="161" r="2.1" fill="#FFC98A" />
                    </g>
                    <g class="rack-led">
                      <circle cx="221" cy="185" r="2" fill="#FFC98A" opacity="0.8" />
                      <circle cx="173" cy="189" r="2" fill="#FFC98A" opacity="0.8" />
                      <circle cx="221" cy="213" r="2" fill="#FFC98A" opacity="0.8" />
                    </g>
                  </g>
                </g>

                <!-- Patch cable: panel port -> switch port, with light pulse -->
                <g class="rack-cable-group" fill="none" stroke-linecap="round">
                  <path class="rack-cable" d="M158 84 C149 94 147 105 157 110 C163 113 172 111 179 107" stroke="#E2A87C" stroke-width="3" />
                  <path class="rack-cable-pulse" d="M158 84 C149 94 147 105 157 110 C163 113 172 111 179 107" pathLength="100" stroke="#F6E7CB" stroke-width="3" />
                </g>

                <!-- Printed frame: rail, posts, top slab -->
                <g class="rack-frame">
                  <path d="M131 55 L135 57 L135 199 L131 197 Z" fill="#C88463" />
                  <path d="M117 204 L129 198 L129 54 L117 60 Z" fill="url(#hlr-print-side)" />
                  <path d="M105 198 L117 204 L117 60 L105 54 Z" fill="url(#hlr-print-front)" />
                  <path d="M229 260 L241 254 L241 110 L229 116 Z" fill="url(#hlr-print-side)" />
                  <path d="M217 254 L229 260 L229 116 L217 110 Z" fill="url(#hlr-print-front)" />
                  <path d="M283 233 L295 227 L295 83 L283 89 Z" fill="url(#hlr-print-side)" />
                  <path d="M105 54 L229 116 L229 104 L105 42 Z" fill="url(#hlr-print-front)" />
                  <path d="M229 116 L295 83 L295 71 L229 104 Z" fill="url(#hlr-print-side)" />
                  <path d="M105 42 L229 104 L295 71 L171 9 Z" fill="url(#hlr-print-top)" />
                  <path d="M186 57 L200 64 L214 57 L200 50 Z" fill="#2E1B10" opacity="0.5" />
                  <path d="M105 42 L229 104 M105 198 L229 260 M105 54 L105 198" stroke="#E8D8BE" stroke-opacity="0.16" stroke-width="1" fill="none" />
                </g>

                <!-- FDM layer texture, printed parts only -->
                <g class="rack-fdm" stroke="#2E1B10" stroke-opacity="0.2" stroke-width="1" fill="none">
                  <path d="M105 78 L117 84 M105 106 L117 112 M105 134 L117 140 M105 162 L117 168" />
                  <path d="M217 130 L229 136 M217 158 L229 164 M217 186 L229 192 M217 214 L229 220 M217 242 L229 248" />
                  <path d="M283 110 L295 104 M283 140 L295 134 M283 170 L295 164 M283 200 L295 194" />
                  <path d="M105 47 L229 109 M105 51 L229 113" />
                  <path d="M105 202 L229 264 M105 206 L229 268" />
                </g>

                <!-- Slow-drifting sheen across the front plane -->
                <g clip-path="url(#hlr-front-clip)">
                  <path class="rack-sheen" d="M150 30 L196 53 L176 292 L130 269 Z" fill="url(#hlr-sheen-grad)" />
                </g>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section aria-labelledby="print-examples-title">
      <div class="container">
        <h2 id="print-examples-title" class="sr-only">Приклади FDM 3D-друку</h2>

        <div class="catalog-controls">
          <div class="catalog-controls__left">
            <p class="catalog-results-count">
              На сторінці <strong>{products.length}</strong> прикладів друку з окремими описами.
            </p>
          </div>
        </div>

        <div class="catalog-layout">
          <aside class="catalog-sidebar">
            <div class="catalog-filter-section is-open">
              <div class="catalog-filter-section__head">
                <span class="catalog-filter-section__label">Про FDM друк</span>
              </div>

              <div class="catalog-filter-section__body">
                <div class="catalog-filter-section__inner">
                  <p class="catalog-results-count">
                    Друк деталей під замовлення для ремонту, прототипування, електроніки,
                    майстерні та невеликих серій.
                  </p>
                </div>
              </div>
            </div>

            <div class="catalog-filter-section is-open">
              <div class="catalog-filter-section__head">
                <span class="catalog-filter-section__label">Напрями</span>
              </div>

              <div class="catalog-filter-section__body">
                <div class="catalog-filter-section__inner">
                  <ul class="catalog-tag-list">
                    <li class="tag tag--copper">PLA</li>
                    <li class="tag tag--copper">PETG</li>
                    <li class="tag tag--copper">Корпуси</li>
                    <li class="tag tag--copper">Прототипи</li>
                  </ul>
                </div>
              </div>
            </div>
          </aside>

          <div class="catalog-content">
            {
              products.length > 0 ? (
                <div class="catalog-grid">
                  {products.map((product) => <ProductCard product={product} />)}
                </div>
              ) : (
                <div class="catalog-no-results">
                  <div class="catalog-no-results__art">∅</div>
                  <h2 class="catalog-no-results__title">Приклади поки що не додані</h2>
                  <p class="catalog-no-results__text">
                    Додай перший приклад у джерело даних, і він зʼявиться тут автоматично.
                  </p>
                </div>
              )
            }
          </div>
        </div>
      </div>
    </section>

    <SkufnyaPromo />

    <section class="catalog-seo" aria-labelledby="services-title">
      <div class="container">
        <div class="catalog-seo__intro">
          <p class="catalog-seo__eyebrow">Послуги</p>
          <h2 id="services-title">Послуги FDM 3D-друку в Києві</h2>
          <p>
            3D-друк на замовлення підходить, коли потрібна одна функціональна деталь,
            невелика партія або швидкий прототип перед запуском виробу. Можна надрукувати
            готову STL/3MF-модель, перевірити посадку деталі, адаптувати корпус під плату
            або зробити кріплення під конкретні розміри.
          </p>
        </div>

        <div class="catalog-seo__grid">
          <article class="catalog-seo__item">
            <h3>3D-друк на замовлення</h3>
            <p>
              FDM друк у Києві для побутових, технічних і робочих задач: адаптери,
              тримачі, кронштейни, кришки, вставки, органайзери та запасні пластикові
              деталі, які складно швидко купити готовими.
            </p>
          </article>

          <article class="catalog-seo__item">
            <h3>Корпуси для електроніки</h3>
            <p>
              Друк корпусів для електроніки з отворами під розʼєми, вентиляцію, кнопки
              та кріплення. Такий формат зручний для плат, контролерів, датчиків,
              блоків живлення, DIY-пристроїв і майстерні.
            </p>
          </article>

          <article class="catalog-seo__item">
            <h3>Прототипування</h3>
            <p>
              Прототипування в Києві допомагає швидко перевірити форму, ергономіку,
              габарити й сумісність деталі перед фінальним виробництвом або замовленням
              дорожчого матеріалу.
            </p>
          </article>
        </div>
      </div>
